@page
@model Index1Model

<!DOCTYPE html>
<html>
<head>
    <title>Not Sistemi</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                background: #f4f6f9;
            }

            .card {
                margin-top: 50px;
                border-radius: 15px;
            }
    </style>
</head>

<body>

    <div class="container">

        <div class="card shadow p-4 col-md-6 mx-auto">

            <h3 class="text-center mb-4">Not Ortalaması Sistemi</h3>

            <form method="post">

                <div class="mb-3">
                    <label>1. Yazılı</label>
                    <input class="form-control" type="number" asp-for="TextBox1" min="0" max="100">
                </div>

                <div class="mb-3">
                    <label>2. Yazılı</label>
                    <input class="form-control" type="number" asp-for="TextBox2" min="0" max="100">
                </div>

                <div class="mb-3">
                    <label>Sözlü</label>
                    <input class="form-control" type="number" asp-for="TextBox3" min="0" max="100">
                </div>

                <button class="btn btn-primary w-100" type="submit">
                    Hesapla
                </button>

            </form>

            <!-- HATALAR -->
            @if (Model.Hatalar.Count > 0)
            {
                <div class="alert alert-danger mt-3">
                    <ul>
                        @foreach (var h in Model.Hatalar)
                        {
                            <li>@h</li>
                        }
                    </ul>
                </div>
            }

            <!-- SONUÇ -->
            @if (Model.Basarili)
            {
                <div class="alert alert-success mt-3 text-center">
                    <h4>Ortalama: @Model.Ortalama</h4>
                </div>
            }

        </div>

    </div>

</body>
</html>